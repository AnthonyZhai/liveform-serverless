# ============================================
# LiveForm 后端环境变量配置（示例）
# 复制此文件为 .env 并填入实际值
# ============================================

# 数据库地址
# 本地开发可用 SQLite（默认值）: sqlite:///./liveform.db
# Railway PostgreSQL 示例: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./liveform.db

# JWT 密钥（生产环境必须修改！）
# 可以用 python -c "import secrets; print(secrets.token_hex(32))" 生成
SECRET_KEY=your-random-secret-key-here

# Token 过期时间（分钟），默认 1440 = 24小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允许的前端域名（逗号分隔）
# 本地开发: http://localhost:5173
# 生产环境: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 文件上传目录
UPLOAD_DIR=backend/uploads
